{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OneThought",
  "version": "0.1.0",
  "identifier": "com.onethought.tauri",
  "build": {
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "OneThought",
        "width": 1200,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "visible": true
      },
      {
        "label": "quick_capture",
        "title": "OneThought",
        "width": 580,
        "height": 300,
        "minWidth": 580,
        "minHeight": 200,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "center": true,
        "url": "index.html#quick"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "想法速记与时间线，Tauri 版。",
    "shortDescription": "OneThought Tauri",
    "category": "Productivity",
    "resources": []
  },
  "plugins": {}
}
